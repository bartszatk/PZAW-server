<form action="<%= action %>" method="post">
  <p>
    <label>Tytuł:<br>
    <input type="text" name="title" value="<%= post.title || "" %>"></label>
  </p>
  <p>
    <label>Treść:<br>
    <textarea name="content" rows="5" cols="40"><%= post.content || "" %></textarea></label>
  </p>
  <button type="submit"><%= buttonLabel %></button>
</form>
