<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>Logowanie</h1>

  <% if (errors.length > 0) { %>
    <div class="errors"><%= errors[0] %></div>
  <% } %>

  <form method="POST">
    <input name="login" placeholder="Login">
    <input type="password" name="password" placeholder="Hasło">
    <button>Zaloguj</button>
  </form>

  <a href="/">Powrót</a>
</body>
</html>